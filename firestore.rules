rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'label', 'images', 'iconName']) &&
             data.id is string && data.id.size() <= 64 &&
             data.label is string && data.label.size() <= 128 &&
             data.images is list && data.images.size() <= 20 &&
             data.iconName in ['Wings', 'Rose', 'Crown', 'ChessKing', 'CrossGothic'];
    }

    function isValidCollaboration(data) {
      return data.keys().hasAll(['productId', 'createdAt']) &&
             data.productId is string && data.productId.size() <= 64 &&
             data.createdAt == request.time &&
             (data.keys().size() == 2 || (data.keys().size() == 3 && data.userId == request.auth.uid));
    }

    // Rules for Products
    match /products/{productId} {
      allow read: if true; // Publicly readable for the gallery
      allow write: if false; // Only admin via console for now
    }

    // Rules for Collaborations (anonymous interest tracking)
    match /collaborations/{collaborationId} {
      allow create: if isValidId(collaborationId) && isValidCollaboration(incoming());
      allow read, update, delete: if false; // Private logs
    }
  }
}
