{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A cap product in the collection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bgColor": { "type": "string" },
        "textColor": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "iconName": { "type": "string", "enum": ["Wings", "Rose", "Crown", "ChessKing", "CrossGothic"] },
        "iconColor": { "type": "string" }
      },
      "required": ["id", "label", "images", "iconName"]
    },
    "Collaboration": {
      "title": "Collaboration",
      "description": "Record of a user expressing interest in collaborating",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of cap products"
    },
    "/collaborations/{collaborationId}": {
      "schema": "Collaboration",
      "description": "Collection of collaboration interests"
    }
  }
}
